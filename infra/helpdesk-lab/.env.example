COMPOSE_PROJECT_NAME=helpdesk_lab
LAB_TIMEZONE=America/Sao_Paulo

# Portas locais do laboratorio
GLPI_HOST_PORT=8088
ZABBIX_WEB_HOST_PORT=8089
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380

# Banco compartilhado do laboratorio
LAB_DB_ROOT_PASSWORD=change_me_lab_root_password

# GLPI
GLPI_DB_NAME=glpi_lab
GLPI_DB_USER=glpi_lab
GLPI_DB_PASSWORD=change_me_glpi_password
GLPI_SKIP_AUTOUPDATE=false

# Zabbix
ZABBIX_DB_NAME=zabbix_lab
ZABBIX_DB_USER=zabbix_lab
ZABBIX_DB_PASSWORD=change_me_zabbix_password
ZABBIX_SERVER_NAME="Helpdesk Lab Zabbix"

# PostgreSQL operacional do backend
OPS_POSTGRES_DB=helpdesk_ops
OPS_POSTGRES_USER=helpdesk_ops
OPS_POSTGRES_PASSWORD=change_me_helpdesk_ops_password
OPS_POSTGRES_SCHEMA=helpdesk_platform

# Redis para fila e retentativas
OPS_REDIS_PASSWORD=change_me_helpdesk_redis_password
