      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "zabbix-db"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT i.name AS Item, latest.value AS Valor, FROM_UNIXTIME(latest.clock) AS Atualizado_em FROM items i JOIN hosts h ON h.hostid = i.hostid JOIN (SELECT hu.itemid, hu.clock, hu.value FROM history_uint hu JOIN (SELECT itemid, MAX(clock) AS maxclock FROM history_uint GROUP BY itemid) lastval ON lastval.itemid = hu.itemid AND lastval.maxclock = hu.clock) latest ON latest.itemid = i.itemid WHERE h.host = '${focus_host}' AND (i.key_ = 'icmpping' OR i.key_ LIKE 'net.tcp.service[%') ORDER BY i.name",
          "refId": "A"
        }
      ],
      "title": "Checks atuais do host focal",
      "transparent": true,
      "type": "table"
    },
