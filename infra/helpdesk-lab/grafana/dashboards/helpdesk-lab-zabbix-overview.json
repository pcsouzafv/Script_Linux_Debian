          "rawSql": "WITH problem_hosts AS (SELECT p.eventid, p.r_eventid, MAX(COALESCE(NULLIF(h.name, ''), h.host)) AS host_display, MAX(h.host) AS host_technical FROM problem p JOIN triggers t ON t.triggerid = p.objectid LEFT JOIN functions f ON f.triggerid = t.triggerid LEFT JOIN items i ON i.itemid = f.itemid LEFT JOIN hosts h ON h.hostid = i.hostid WHERE p.source = 0 AND p.object = 0 GROUP BY p.eventid, p.r_eventid) SELECT COUNT(DISTINCT host_display) AS value FROM problem_hosts WHERE r_eventid IS NULL AND host_technical LIKE '${fleet}'",
