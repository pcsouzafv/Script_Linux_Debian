          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH problem_hosts AS (SELECT p.eventid, p.r_eventid, t.triggerid, MAX(h.host) AS host_technical FROM problem p JOIN triggers t ON t.triggerid = p.objectid LEFT JOIN functions f ON f.triggerid = t.triggerid LEFT JOIN items i ON i.itemid = f.itemid LEFT JOIN hosts h ON h.hostid = i.hostid WHERE p.source = 0 AND p.object = 0 GROUP BY p.eventid, p.r_eventid, t.triggerid), problem_services AS (SELECT ph.eventid, COALESCE(MAX(CASE WHEN tt.tag = 'service' THEN tt.value END), 'sem-tag') AS service FROM problem_hosts ph JOIN triggers t ON t.triggerid = ph.triggerid LEFT JOIN trigger_tag tt ON tt.triggerid = t.triggerid GROUP BY ph.eventid) SELECT ps.service AS metric, COUNT(*) AS value FROM problem_hosts ph JOIN problem_services ps ON ps.eventid = ph.eventid WHERE ph.r_eventid IS NULL AND ph.host_technical LIKE '${fleet}' GROUP BY ps.service ORDER BY value DESC, metric",
