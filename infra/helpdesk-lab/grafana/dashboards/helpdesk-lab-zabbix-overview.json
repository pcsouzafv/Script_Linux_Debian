          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH problem_hosts AS (SELECT p.eventid, p.severity, p.clock, MAX(h.host) AS host_technical FROM problem p JOIN triggers t ON t.triggerid = p.objectid LEFT JOIN functions f ON f.triggerid = t.triggerid LEFT JOIN items i ON i.itemid = f.itemid LEFT JOIN hosts h ON h.hostid = i.hostid WHERE p.source = 0 AND p.object = 0 GROUP BY p.eventid, p.severity, p.clock) SELECT $__unixEpochGroupAlias(clock, $__interval), COUNT(*) AS value, CASE severity WHEN 5 THEN 'Disaster' WHEN 4 THEN 'High' WHEN 3 THEN 'Average' WHEN 2 THEN 'Warning' WHEN 1 THEN 'Info' ELSE 'Not classified' END AS metric FROM problem_hosts WHERE $__unixEpochFilter(clock) AND host_technical LIKE '${fleet}' GROUP BY time, metric ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Novos problemas por severidade",
      "transparent": true,
      "type": "timeseries"
