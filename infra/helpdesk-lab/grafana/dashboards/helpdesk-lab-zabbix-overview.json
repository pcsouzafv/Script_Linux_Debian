          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH problem_hosts AS (SELECT p.eventid, p.name, p.severity, p.clock, p.acknowledged, p.r_eventid, t.manual_close, COALESCE(MAX(NULLIF(h.name, '')), MAX(h.host)) AS host_display, MAX(h.host) AS host_technical FROM problem p JOIN triggers t ON t.triggerid = p.objectid LEFT JOIN functions f ON f.triggerid = t.triggerid LEFT JOIN items i ON i.itemid = f.itemid LEFT JOIN hosts h ON h.hostid = i.hostid WHERE p.source = 0 AND p.object = 0 GROUP BY p.eventid, p.name, p.severity, p.clock, p.acknowledged, p.r_eventid, t.manual_close) SELECT eventid AS Evento, host_display AS Host, CASE severity WHEN 5 THEN 'Disaster' WHEN 4 THEN 'High' WHEN 3 THEN 'Average' WHEN 2 THEN 'Warning' WHEN 1 THEN 'Info' ELSE 'Not classified' END AS Severidade, name AS Problema, FROM_UNIXTIME(clock) AS Aberto_em, SEC_TO_TIME(GREATEST(UNIX_TIMESTAMP() - clock, 0)) AS Duracao, IF(acknowledged = 1, 'Sim', 'Nao') AS Acknowledged, IF(manual_close = 1, 'Sim', 'Nao') AS Manual_close FROM problem_hosts WHERE r_eventid IS NULL AND host_technical LIKE '${fleet}' ORDER BY severity DESC, clock DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Fila ativa de problemas",
