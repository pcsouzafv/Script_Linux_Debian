HELPDESK_APP_NAME="Helpdesk Orchestrator"
HELPDESK_ENVIRONMENT=development
HELPDESK_API_PREFIX=/api/v1
HELPDESK_API_HOST=127.0.0.1
HELPDESK_API_PORT=18001
HELPDESK_API_PORT_MAX=18010
HELPDESK_API_PORT_STRICT=false
HELPDESK_API_ACCESS_TOKEN=
HELPDESK_API_ACCESS_TOKEN_PREVIOUS=
HELPDESK_AUDIT_ACCESS_TOKEN=
HELPDESK_AUDIT_ACCESS_TOKEN_PREVIOUS=
HELPDESK_AUTOMATION_ACCESS_TOKEN=
HELPDESK_AUTOMATION_ACCESS_TOKEN_PREVIOUS=
HELPDESK_AUTOMATION_READ_ACCESS_TOKEN=
HELPDESK_AUTOMATION_READ_ACCESS_TOKEN_PREVIOUS=
HELPDESK_AUTOMATION_APPROVAL_ACCESS_TOKEN=
HELPDESK_AUTOMATION_APPROVAL_ACCESS_TOKEN_PREVIOUS=
# producao deve usar glpi; mock-file deve ficar restrito a laboratorio e testes
HELPDESK_IDENTITY_PROVIDER=glpi
HELPDESK_IDENTITY_STORE_PATH=data/identities.json
HELPDESK_IDENTITY_GLPI_USER_PROFILES=Self-Service
HELPDESK_IDENTITY_GLPI_TECHNICIAN_PROFILES=Technician
HELPDESK_IDENTITY_GLPI_SUPERVISOR_PROFILES=Supervisor
HELPDESK_IDENTITY_GLPI_ADMIN_PROFILES=Super-Admin,Admin,Administrator

# GLPI
HELPDESK_GLPI_BASE_URL=http://localhost/apirest.php
HELPDESK_GLPI_APP_TOKEN=
HELPDESK_GLPI_USER_TOKEN=
HELPDESK_GLPI_USERNAME=
HELPDESK_GLPI_PASSWORD=
HELPDESK_GLPI_QUEUE_GROUP_MAP=

# Zabbix
HELPDESK_ZABBIX_BASE_URL=http://localhost/zabbix/api_jsonrpc.php
HELPDESK_ZABBIX_API_TOKEN=
HELPDESK_ZABBIX_USERNAME=
HELPDESK_ZABBIX_PASSWORD=

# WhatsApp - configuracao comum
HELPDESK_WHATSAPP_VERIFY_TOKEN=
HELPDESK_WHATSAPP_VALIDATE_SIGNATURE=true
# auto prioriza Evolution quando ela estiver configurada; use meta ou evolution explicitamente para evitar ambiguidade
HELPDESK_WHATSAPP_DELIVERY_PROVIDER=auto

# WhatsApp - Meta Cloud API
HELPDESK_WHATSAPP_ACCESS_TOKEN=
HELPDESK_WHATSAPP_PHONE_NUMBER_ID=
HELPDESK_WHATSAPP_PUBLIC_NUMBER=
HELPDESK_WHATSAPP_APP_SECRET=

# WhatsApp - Evolution API
HELPDESK_EVOLUTION_BASE_URL=http://localhost:8080
HELPDESK_EVOLUTION_API_KEY=
HELPDESK_EVOLUTION_INSTANCE_NAME=helpdeskAutomacao
HELPDESK_EVOLUTION_WEBHOOK_SECRET=
# Algumas versões da Evolution entregam o remetente como @lid em vez de telefone.
# Cadastre apenas mapeamentos confirmados: {"LID":"telefone cadastrado no GLPI"}
HELPDESK_EVOLUTION_LID_PHONE_MAP=

# Persistencia operacional e fila de automacao
HELPDESK_OPERATIONAL_POSTGRES_DSN=
HELPDESK_OPERATIONAL_POSTGRES_SCHEMA=helpdesk_platform
HELPDESK_OPERATIONAL_AUDIT_RETENTION_DAYS=30
HELPDESK_OPERATIONAL_JOB_RETENTION_DAYS=30
HELPDESK_AUTOMATION_APPROVAL_TIMEOUT_MINUTES=1440
HELPDESK_OPERATIONAL_PAYLOAD_MAX_DEPTH=6
HELPDESK_OPERATIONAL_PAYLOAD_MAX_LIST_ITEMS=20
HELPDESK_OPERATIONAL_PAYLOAD_MAX_OBJECT_KEYS=50
HELPDESK_OPERATIONAL_PAYLOAD_MAX_STRING_LENGTH=1024
HELPDESK_REDIS_URL=
HELPDESK_AUTOMATION_WORKER_MAX_ATTEMPTS=3
HELPDESK_AUTOMATION_RETRY_BASE_SECONDS=5
HELPDESK_AUTOMATION_RETRY_MAX_SECONDS=300
HELPDESK_AUTOMATION_RUNNER_BASE_DIR=../infra/automation-runner/projects
HELPDESK_AUTOMATION_RUNNER_TIMEOUT_SECONDS=120

# IA do bot
HELPDESK_LLM_ENABLED=true
HELPDESK_LLM_PROVIDER=ollama
HELPDESK_LLM_BASE_URL=http://127.0.0.1:11434
HELPDESK_LLM_API_KEY=
HELPDESK_LLM_MODEL=llama3.1
HELPDESK_LLM_REQUEST_TIMEOUT=45
HELPDESK_LLM_TEMPERATURE=0.2
HELPDESK_OPENAI_API_KEY=
HELPDESK_GROQ_API_KEY=
HELPDESK_GEMINI_API_KEY=
HELPDESK_ANTHROPIC_API_KEY=
