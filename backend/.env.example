HELPDESK_APP_NAME="Helpdesk Orchestrator"
HELPDESK_ENVIRONMENT=development
HELPDESK_API_PREFIX=/api/v1
HELPDESK_API_HOST=127.0.0.1
HELPDESK_API_PORT=18001
HELPDESK_API_PORT_MAX=18010
HELPDESK_API_PORT_STRICT=false
HELPDESK_IDENTITY_PROVIDER=glpi
HELPDESK_IDENTITY_STORE_PATH=data/identities.json
HELPDESK_IDENTITY_GLPI_USER_PROFILES=Self-Service
HELPDESK_IDENTITY_GLPI_TECHNICIAN_PROFILES=Technician
HELPDESK_IDENTITY_GLPI_SUPERVISOR_PROFILES=Supervisor
HELPDESK_IDENTITY_GLPI_ADMIN_PROFILES=Super-Admin,Admin,Administrator

# GLPI
HELPDESK_GLPI_BASE_URL=http://localhost/apirest.php
HELPDESK_GLPI_APP_TOKEN=
HELPDESK_GLPI_USER_TOKEN=
HELPDESK_GLPI_USERNAME=
HELPDESK_GLPI_PASSWORD=

# Zabbix
HELPDESK_ZABBIX_BASE_URL=http://localhost/zabbix/api_jsonrpc.php
HELPDESK_ZABBIX_API_TOKEN=
HELPDESK_ZABBIX_USERNAME=
HELPDESK_ZABBIX_PASSWORD=

# WhatsApp
HELPDESK_WHATSAPP_VERIFY_TOKEN=local-verify-token
HELPDESK_WHATSAPP_VALIDATE_SIGNATURE=false
HELPDESK_WHATSAPP_DELIVERY_PROVIDER=auto
HELPDESK_WHATSAPP_ACCESS_TOKEN=
HELPDESK_WHATSAPP_PHONE_NUMBER_ID=
HELPDESK_WHATSAPP_PUBLIC_NUMBER=
HELPDESK_WHATSAPP_APP_SECRET=
HELPDESK_EVOLUTION_BASE_URL=http://localhost:8080
HELPDESK_EVOLUTION_API_KEY=
HELPDESK_EVOLUTION_INSTANCE_NAME=helpdeskAutomacao
HELPDESK_EVOLUTION_WEBHOOK_SECRET=

# IA do bot
HELPDESK_LLM_ENABLED=true
HELPDESK_LLM_PROVIDER=ollama
HELPDESK_LLM_BASE_URL=http://127.0.0.1:11434
HELPDESK_LLM_API_KEY=
HELPDESK_LLM_MODEL=llama3.1
HELPDESK_LLM_REQUEST_TIMEOUT=45
HELPDESK_LLM_TEMPERATURE=0.2
HELPDESK_OPENAI_API_KEY=
HELPDESK_GROQ_API_KEY=
HELPDESK_GEMINI_API_KEY=
HELPDESK_ANTHROPIC_API_KEY=
